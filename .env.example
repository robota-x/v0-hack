# BrightData — Instagram scraper
# Get token from: BrightData Dashboard → API settings
# Collector IDs ("instagram_profile", "instagram_hashtag") must be verified in your BrightData dashboard — they may be account-specific slugs
BRIGHTDATA_API_TOKEN=

# Anthropic — Claude API (distil + rank steps)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Mubit AI — memory layer (stretch goal)
MUBIT_API_KEY=

# Web Push — VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Telegram notifications — get from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Neon / Vercel Postgres
DATABASE_URL=
